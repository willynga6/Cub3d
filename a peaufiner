#include "get_next_line.h"
#include <fcntl.h>

int	count_lines(char *filename, t_malloc **lst_malloc)
{
    int		fd;
    int		line_count;
    char	*line;

    line_count = 0;
    fd = open(filename, O_RDONLY);
    if (fd < 0)
        return (-1);
    
    // Lire toutes les lignes et compter
    line = get_next_line(lst_malloc, fd);
    while (line)
    {
        line_count++;
        line = get_next_line(lst_malloc, fd);
    }
    
    // Fermer le fichier
    close(fd);
    
    return (line_count);
}

int	main(void)
{
    t_malloc	*lst_malloc;
    int			nb_lines;
    int			fd;
    char		*line;

    init_lst_malloc(&lst_malloc);
    
    // Première lecture: compter les lignes
    nb_lines = count_lines("mon_fichier.txt", &lst_malloc);
    printf("Nombre de lignes: %d\n", nb_lines);
    
    // Réouvrir le fichier à zéro
    fd = open("mon_fichier.txt", O_RDONLY);
    
    // Deuxième lecture: traiter le fichier
    line = get_next_line(&lst_malloc, fd);
    while (line)
    {
        printf("%s", line);
        line = get_next_line(&lst_malloc, fd);
    }
    
    close(fd);
    free_lst_malloc(&lst_malloc);
    return (0);
}